# ====================================================
# Analytiq — Environment Variables Template
# ====================================================
# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.
# ====================================================

# ── Core infrastructure ──────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/analytiq
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# Redis URL — docker-compose exposes Redis on port 6380 to avoid conflicts
REDIS_URL=redis://localhost:6380

# BullMQ queue name (shared between ingestion-api and worker)
EVENTS_QUEUE_NAME=events

# ── Ingestion API (port 3001) ─────────────────────────
INGESTION_API_PORT=3001

# Tenant token cache duration in Redis (seconds)
TENANT_CACHE_TTL_SECONDS=300

# Sliding-window rate limit applied per tenant token
INGEST_RATE_LIMIT_MAX=1000
INGEST_RATE_LIMIT_WINDOW_SECONDS=60

# ── Worker ───────────────────────────────────────────
WORKER_BATCH_SIZE=50
WORKER_BATCH_FLUSH_INTERVAL_MS=1000
WORKER_CONCURRENCY=10

# URL of the dashboard-api Socket.io server — the worker connects here
# to relay processed events to the frontend in realtime
DASHBOARD_REALTIME_URL=http://localhost:3002

# Shared secret used to authenticate the worker's Socket.io connection
# MUST match DASHBOARD_WORKER_TOKEN below
DASHBOARD_WORKER_TOKEN=change-me-in-production

# ── Dashboard API (port 3002) ─────────────────────────
DASHBOARD_API_PORT=3002

# Supabase project URL — used for JWKS-based JWT verification
# Leave blank to use HS256 with SUPABASE_JWT_SECRET only (local dev)
SUPABASE_URL=https://your-project-ref.supabase.co

# JWT secret — used for HS256 tokens issued by `npm run issue-jwt`
# In production with Supabase, this is your project JWT secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Allowed CORS origin for the dashboard frontend
FRONTEND_ORIGIN=http://localhost:5173

# ── Frontend (Vite reads VITE_* vars from root .env) ──
VITE_DASHBOARD_API_URL=http://localhost:3002
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
