{
  "name": "@analytiq/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format iife --globalName analytiq --minify --dts --outDir dist",
    "dev": "tsup src/index.ts --format iife --globalName analytiq --watch --outDir dist",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.2.4",
    "typescript": "^5.5.4"
  }
}
